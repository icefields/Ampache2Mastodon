# Ampache config
AMPACHE_SERVER=https://your-ampache-server.com
AMPACHE_USER=your_service_account_username
AMPACHE_PASSWORD=your_service_account_password
AMPACHE_TARGET_USER=your_listening_username

# Mastodon config (main post account)
MASTODON_INSTANCE=https://your-mastodon-instance.com
MASTODON_TOKEN_FILE=/path/to/your/mastodon_token_file

# Pixelfed config
PIXELFED_INSTANCE=https://pixelfed.social
PIXELFED_TOKEN_FILE=/path/to/your/pixelfed_token_file

# Cross-post accounts (boost + favourite)
# Fosstodon
FOSTODON_INSTANCE=https://fosstodon.org
FOSTODON_USERNAME=your_username
FOSTODON_TOKEN_FILE=/path/to/your/fosstodon_token_file

# Mastodon.social (or another instance)
MASTODON_SOCIAL_INSTANCE=https://mastodon.social
MASTODON_SOCIAL_USERNAME=your_username
MASTODON_SOCIAL_TOKEN_FILE=/path/to/your/mastodon_social_token_file

# Lyrics API
LYRICS_API_URL=https://your-lyrics-api.com/api/lyrics

# State file (relative to script directory)
STATE_FILE=posted_songs_state.json